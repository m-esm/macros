{
  "manifest_version": 3,
  "name": "Macros",
  "version": "1.1.0",
  "description": "Nutrition grid for your grocery shopping — compare products by calories, protein, fat, carbs, and fiber.",
  "author": "Mohsen",
  "homepage_url": "https://github.com/m-esm/macros",
  "permissions": ["storage"],
  "host_permissions": [
    "https://wolt.com/*",
    "https://prodinfo.wolt.com/*",
    "https://consumer-api.wolt.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://wolt.com/*"],
      "js": ["src/injector.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://wolt.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" }
}
